{
  "manifest_version": 3,
  "name": "LaTeX render",
  "version": "1.9",
  "description": "Local LaTeX Renderer for Element, Telegram, OpenClaw,",
  "permissions": [
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "inject_url.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js",
        "tex-mml-svg.js",
        "extensions_bundle.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/svg/dynamic/*.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}